# ============================================================
# Scientific Journal Pipeline environment template
# Copy this file to .env and fill real secrets locally/on EC2.
# Never commit the real .env file.
# ============================================================

# SQL Server
# Local Windows examples:
#   SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
#   SQLSERVER_SERVER=LAPTOP-XXXX\SQLEXPRESS
#
# Docker/Linux EC2 examples:
#   SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
#   SQLSERVER_SERVER=sqlserver,1433
#   SQLSERVER_SERVER=host.docker.internal,1433
#   SQLSERVER_SERVER=<EC2_PUBLIC_IP>,1433
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_SERVER=sqlserver,1433
SQLSERVER_DATABASE=scientific_journal_tracking_db
SQLSERVER_USERNAME=pipeline_user
SQLSERVER_PASSWORD=<pipeline_user_password>
SQLSERVER_TRUSTED_CONNECTION=no
SQLSERVER_ENCRYPT=no
SQLSERVER_TRUST_SERVER_CERTIFICATE=yes

# OpenAlex API
OPENALEX_BASE_URL=https://api.openalex.org
OPENALEX_MAILTO=<your_email>
OPENALEX_API_KEY=<optional_openalex_api_key>

# Pipeline runtime defaults
OPENALEX_PAGE_DELAY_SECONDS=2
OPENALEX_KEYWORD_DELAY_SECONDS=3

# Docker Compose SQL Server bootstrap
# Used only by the sqlserver container.
MSSQL_SA_PASSWORD=<strong_sa_password>
